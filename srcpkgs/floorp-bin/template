# Template file for 'floorp-bin'
pkgname=floorp-bin
version=12.12.1
revision=1
short_desc="Floorp browser"
maintainer="Luc-Saccoccio <lucsaccoccio@disroot.org>"
license="custom"
homepage="https://floorp.app/"
distfiles="https://github.com/Floorp-Projects/Floorp/releases/download/v${version}/floorp-linux-x86_64.tar.xz"
checksum=7f50d5d805e3acd401b933aa039d01712237d975c5d8306d46006ae2363d3080
nopie=yes

do_install() {
	vmkdir usr/lib/floorp
	vcopy * usr/lib/floorp

	vmkdir usr/bin
	ln -sf /usr/lib/floorp/floorp ${DESTDIR}/usr/bin

	vinstall ${FILESDIR}/floorp.desktop 644 usr/share/applications
}
